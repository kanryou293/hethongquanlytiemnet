# Bỏ qua thư mục thư viện của Node.js ở thư mục gốc
node_modules/

# Bỏ qua các file môi trường chứa mật khẩu, cấu hình database
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Bỏ qua các file log hệ thống
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Bỏ qua thư mục build khi đóng gói (nếu có dùng Vite/React ở frontend)
dist/
build/

# Bỏ qua file cấu hình của hệ điều hành hoặc IDE
.DS_Store
.vscode/